---
import '@/styles/reset.css'
import '@/styles/tokens.css'
import '@/styles/globals.css'
import '@/styles/utils.css'

import { ClientRouter } from 'astro:transitions'
import { SEO } from 'astro-seo'
import { Font } from 'astro:assets'

import AgentationWrapper from '@/components/helpers/AgentationWrapper'
import GridDebugOverlay from '@/components/helpers/GridDebugOverlay.svelte'
import ParcCredits from '@/components/helpers/ParcCredits.astro'
import SiteFooter from '@/components/SiteFooter.astro'
import SiteHeader from '@/components/SiteHeader.astro'
import { getSettings } from '@/data/sanity'
import { isDevMode } from '@/utils'

import VisualEditing from '../components/VisualEditing.svelte'

interface Props {
  title?: string
  description?: string
  image?: string
  isPreview?: boolean
  pagePath?: string
  hideFooter?: boolean
  hideHeader?: boolean
  contentBackground?: string
}

const {
  title,
  description,
  image = '/og-image.png',
  isPreview = false,
  pagePath = '',
  hideFooter = false,
  hideHeader = false,
  contentBackground,
} = Astro.props

let settings = null
try {
  settings = await getSettings({ preview: isPreview })
} catch (error) {
  console.error('[BaseLayout] Unable to load settings:', error)
}

const resolvedTitle = title || 'Jacquard Espaces Verts'
const resolvedDescription = description || settings?.shortDescription || 'Jacquard Espaces Verts'

const siteUrl = import.meta.env.SITE_URL || 'http://localhost:4321'
const enableFeedback = import.meta.env.PUBLIC_ENABLE_FEEDBACK === 'true'

const agentationMode = isDevMode ? 'dev' : 'review'
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- TODO: Uncomment for custom fonts with preload -->
    <Font cssVariable="--font-sans" preload />
    <!-- <Font cssVariable="--font-classic" preload /> -->
    <SEO
      title={resolvedTitle}
      description={resolvedDescription}
      openGraph={{
        basic: {
          title: resolvedTitle,
          type: 'website',
          image: image,
          url: siteUrl,
        },
        optional: {
          description: resolvedDescription,
        },
      }}
    />
    <ClientRouter />
  </head>
  <body>
    {isDevMode && <GridDebugOverlay client:only="svelte" />}
    {!hideHeader && <SiteHeader pagePath={pagePath} />}
    <div
      class="site-content"
      style={contentBackground ? `background: ${contentBackground}` : undefined}
    >
      <slot />
    </div>
    {!hideFooter && <SiteFooter isPreview={isPreview} settings={settings} />}
    {isPreview && <VisualEditing pagePath={pagePath} client:only="svelte" transition:persist />}
    {enableFeedback && <AgentationWrapper client:only="react" mode={agentationMode} />}
    {!isDevMode && <ParcCredits />}
  </body>
</html>

<style is:global>
  /* Suppress native View Transition animation — fades driven by JS events */
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation: none;
  }

  .site-content {
    position: relative;
    z-index: 2;
    background-color: var(--color-white);
    border-radius: 0 0 var(--size-20) var(--size-20);
  }
</style>

<script>
  import type { TransitionBeforePreparationEvent } from 'astro:transitions/client'

  const FADE_MS = 330

  const prefersReducedMotion = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches

  function fadeOut(el: HTMLElement): Promise<void> {
    if (prefersReducedMotion()) {
      el.style.opacity = '0'
      return Promise.resolve()
    }
    return new Promise((resolve) => {
      el.style.transition = `opacity ${FADE_MS}ms ease`
      el.style.opacity = '0'
      setTimeout(resolve, FADE_MS)
    })
  }

  function fadeIn(el: HTMLElement): void {
    if (prefersReducedMotion()) {
      el.style.opacity = '1'
      el.style.removeProperty('transition')
      return
    }
    /* Force the browser to paint opacity:0 before transitioning to 1 */
    el.style.transition = 'none'
    el.style.opacity = '0'
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        el.style.transition = `opacity ${FADE_MS}ms ease`
        el.style.opacity = '1'
        setTimeout(() => {
          el.style.removeProperty('transition')
          el.style.removeProperty('opacity')
        }, FADE_MS + 50)
      })
    })
  }

  /* Fade out the old page before the new one is fetched */
  document.addEventListener('astro:before-preparation', (ev) => {
    const e = ev as TransitionBeforePreparationEvent
    const originalLoader = e.loader
    e.loader = async () => {
      await fadeOut(document.body)
      await originalLoader()
    }
  })

  /* Fade in the new page after DOM swap */
  document.addEventListener('astro:after-swap', () => {
    fadeIn(document.body)
  })
</script>
