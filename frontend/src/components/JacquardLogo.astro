---
/**
 * Jacquard Espaces Verts — expanded wordmark + leaf logo.
 * Accepts a `color` prop: 'green' | 'black' | 'white' (default: 'black').
 */
interface Props {
  color?: 'green' | 'black' | 'white'
}

const colorMap = {
  green: 'var(--color-primary)',
  black: 'var(--color-black)',
  white: 'var(--color-white)',
} as const

const { color = 'green' } = Astro.props
const fill = colorMap[color]
