---
/**
 * SiteFooter
 *
 * Sticky bottom footer with about, expertise, and contact sections.
 * Accepts an optional `settings` prop to avoid re-fetching data already
 * loaded by BaseLayout. Falls back to its own fetch when the prop is omitted
 * (e.g. when rendered outside the main layout).
 */
import JacquardLogo from '@/components/JacquardLogo.astro'
import { getSettings, getExpertises } from '@/data/sanity'

type SettingsData = Awaited<ReturnType<typeof getSettings>>

interface Props {
  isPreview?: boolean
  settings?: SettingsData
}

const { isPreview = false, settings: settingsProp } = Astro.props

const ALLOWED_SOCIAL_HOSTS = {
  instagram: new Set(['instagram.com', 'www.instagram.com']),
  linkedin: new Set(['linkedin.com', 'www.linkedin.com']),
}

function sanitizeExternalUrl(rawUrl: string, allowedHosts: Set<string>): string | null {
  try {
    const parsed = new URL(rawUrl)
    const protocol = parsed.protocol.toLowerCase()
    if (protocol !== 'https:' && protocol !== 'http:') {
      return null
    }

    const hostname = parsed.hostname.toLowerCase()
    if (!allowedHosts.has(hostname)) {
      return null
    }

    return parsed.toString()
  } catch {
    return null
  }
}

let settings: SettingsData = settingsProp ?? null
let expertises: Awaited<ReturnType<typeof getExpertises>> = null
try {
  if (!settings) {
    settings = await getSettings({ preview: isPreview })
  }
  expertises = await getExpertises({ preview: isPreview })
} catch (error) {
  console.error('[SiteFooter] Unable to load footer data:', error)
}

const instagramUrl = settings?.instagram
  ? sanitizeExternalUrl(settings.instagram, ALLOWED_SOCIAL_HOSTS.instagram)
  : null
const linkedinUrl = settings?.linkedin
  ? sanitizeExternalUrl(settings.linkedin, ALLOWED_SOCIAL_HOSTS.linkedin)
  : null
---

{
  settings && (
    <footer class="site-footer">
      <div class="footer-logo">
        <JacquardLogo color="white" />
      </div>

      <div class="footer-content main-grid">
        <section class="footer-about">
          <h2>À propos</h2>
          <p>{settings.shortDescription}</p>
        </section>
        {expertises && expertises.length > 0 && (
          <section class="footer-expertise">
            <h2>Expert en</h2>
            <ul>
              {expertises.map((expertise) => (
                <li>{expertise.title}</li>
              ))}
            </ul>
          </section>
        )}

        <section class="footer-links">
          {settings.telephone && <a href={`tel:${settings.telephone}`}>Téléphone</a>}
          {settings.email && <a href={`mailto:${settings.email}`}>Mail</a>}
          {instagramUrl && (
            <a href={instagramUrl} target="_blank" rel="noopener noreferrer">
              Instagram
            </a>
          )}
          {linkedinUrl && (
            <a href={linkedinUrl} target="_blank" rel="noopener noreferrer">
              LinkedIn
            </a>
          )}
        </section>
      </div>
    </footer>
  )
}

<style is:global>
  .site-footer {
    position: sticky;
    bottom: 0;
    z-index: 1;
    background: var(--color-primary);
    color: var(--color-secondary);
    display: flex;
    flex-direction: column;
    gap: var(--size-40);
    padding-block: var(--size-20);
  }

  .footer-logo {
    opacity: 0;
    width: 100%;
  }

  .footer-logo svg {
    width: 100%;
    height: auto;
    display: block;
    color: var(--color-secondary);
  }

  .footer-content {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    align-items: start;
    gap: 0;
  }

  .site-footer h2 {
    font-size: var(--text-12);
    text-transform: uppercase;
    margin-bottom: var(--size-16);
  }

  .site-footer p,
  .site-footer li {
    font-size: var(--text-16);
    line-height: var(--line-height-125);
  }

  .site-footer ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-about {
    grid-column: 1 / 4;
    padding-left: var(--size-20);
  }

  .footer-expertise {
    grid-column: 4 / 7;
  }

  .footer-expertise ul {
    display: grid;
    gap: var(--size-8);
  }

  .footer-links {
    grid-column: 7 / -1;
    display: flex;
    flex-wrap: wrap;
    gap: var(--size-24);
    justify-content: space-between;
    align-items: end;
    margin-top: auto;
    padding-right: var(--size-20);
  }

  .footer-links a {
    color: var(--color-secondary);
    text-decoration: none;
    font-size: var(--text-30);
  }

  .footer-links a:focus-visible,
  .footer-links a:hover {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .footer-content {
      display: flex;
      flex-direction: column;
      gap: var(--size-24);
    }

    .footer-about,
    .footer-expertise {
      margin-bottom: var(--size-16);
    }

    .footer-links {
      align-items: center;
    }
  }
</style>
